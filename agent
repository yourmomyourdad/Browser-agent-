const express = require("express");
const { chromium } = require("playwright");
const http = require("http");
const { Server } = require("socket.io");
const app = express();
const server = http.createServer(app);
const io = new Server(server);
const { spawn } = require("child_process");

const { execSync } = require("child_process");

const info = execSync("pactl info").toString();

const match = info.match(/Server String:\s*(.+)/);

if (!match)
    throw new Error("Couldn't find PulseAudio server");

const pulseServer = "unix:" + match[1].trim();

console.log(pulseServer);

process.env.PULSE_SERVER = pulseServer;
process.env.PULSE_SINK = "NullSink";

io.on("connection", (socket) => {

    socket.on("click", async ({ x, y }) => {
        await page.mouse.click(x, y);
    });

    socket.on("key", async (key) => {
    await page.keyboard.press(key);
}); 
});
let browser;
let page;

async function startBrowser() {
    console.log(process.env.PULSE_SERVER);
    console.log(process.env.PULSE_SINK);
    browser = await chromium.launch({
        headless: true
        ignoreDefaultArgs: ["--mute-audio"]
    });

    page = await browser.newPage({
    viewport: { width: 1280, height: 720 }
});
page.on("console", msg => {
    console.log("[BROWSER]", msg.text());
});
    console.log("Browser ready");

await page.goto("https://google.com");

await page.screencast.start({
    size: { width: 1280, height: 720 },
    onFrame: ({ data }) => {
        const base64 = data.toString("base64");
        io.emit("frame", base64);
    }
});

await page.evaluate(async () => {
    const ctx = new AudioContext();
    await ctx.resume();

    console.log("state:", ctx.state);
    console.log("sampleRate:", ctx.sampleRate);
    console.log("audio state:", ctx.state);
    console.log("destination sampleRate:", ctx.sampleRate);
    console.log("osc started at:", ctx.currentTime);
   

    const osc = new OscillatorNode(ctx, {
        type: "sine",
        frequency: 440
    });

    const gain = new GainNode(ctx, {
        gain: 0.05
    });

    osc.connect(gain);
    gain.connect(ctx.destination);

    osc.start();

    // Keep references so the browser doesn't garbage collect them
    window.__ctx = ctx;
    window.__osc = osc;
    window.__gain = gain;

    console.log("Oscillator started");

});
}


app.get("/dom", async (req, res) => {

    const dom = await page.evaluate(() => {

        function serialize(element) {

            return {
                tag: element.tagName,
                text: element.innerText,
                children: [...element.children]
                    .map(serialize)
            };

        }

        return serialize(document.body);

    });

    res.json(dom);

});

app.get("/html", async (req, res) => {

    const html = await page.content();

    res.send(html);

});

app.get("/screenshot", async (req, res) => {

    const buffer = await page.screenshot({
        type: "png"
    });

    res.set("Content-Type", "image/png");
    res.send(buffer);

});

app.get("/", (req, res) => {
    res.sendFile(__dirname + "/console.html");
});

app.get("/navigate", async (req, res) => {

    await page.goto(req.query.url);

    res.send("Navigation complete");

});

app.get("/title", async (req, res) => {

    const title = await page.title();

    res.send(title);

});

startBrowser().then(() => {

    server.listen(3000, () => {
        console.log("Agent running");
    });
});
