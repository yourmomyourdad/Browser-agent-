const express = require("express");
const { chromium } = require("playwright");
const http = require("http");
const { Server } = require("socket.io");
const app = express();
const server = http.createServer(app);
const io = new Server(server);
const { spawn } = require("child_process");
const ffmpeg = spawn("ffmpeg", [
    "-f", "pulse",        // or "dshow" on windows
    "-i", "default",
    "-ac", "1",
    "-ar", "44100",
    "-f", "s16le",
    "-"
]);

ffmpeg.stdout.on("data", (chunk) => {
    console.log("AUDIO", chunk.length);
    io.emit("audio", chunk);
});

io.on("connection", (socket) => {

    socket.on("click", async ({ x, y }) => {
        await page.mouse.click(x, y);
    });

    socket.on("key", async (key) => {
    await page.keyboard.press(key);
}); 
});
let browser;
let page;

async function startBrowser() {

    browser = await chromium.launch({
        headless: true
    });

    page = await browser.newPage({
    viewport: { width: 1280, height: 720 }
});

    console.log("Browser ready");

await page.goto("https://google.com");

await page.screencast.start({
    size: { width: 1280, height: 720 },
    onFrame: ({ data }) => {
        const base64 = data.toString("base64");
        io.emit("frame", base64);
    }
});
}


app.get("/dom", async (req, res) => {

    const dom = await page.evaluate(() => {

        function serialize(element) {

            return {
                tag: element.tagName,
                text: element.innerText,
                children: [...element.children]
                    .map(serialize)
            };

        }

        return serialize(document.body);

    });

    res.json(dom);

});

app.get("/html", async (req, res) => {

    const html = await page.content();

    res.send(html);

});

app.get("/screenshot", async (req, res) => {

    const buffer = await page.screenshot({
        type: "png"
    });

    res.set("Content-Type", "image/png");
    res.send(buffer);

});

app.get("/", (req, res) => {
    res.sendFile(__dirname + "/console.html");
});

app.get("/navigate", async (req, res) => {

    await page.goto(req.query.url);

    res.send("Navigation complete");

});

app.get("/title", async (req, res) => {

    const title = await page.title();

    res.send(title);

});

startBrowser().then(() => {

    server.listen(3000, () => {
        console.log("Agent running");
    });
});
